{
  "name": "Smart-store",
  "version": "1.0.0",
  "description": "Smart Store – Warehouse Management System Desktop Client",
  "main": "src/main.js",
  "author": "Smart Store",
  "license": "MIT",
  "scripts": {
    "start":       "electron .",
    "build:win":   "electron-builder --win",
    "build:mac":   "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "dependencies": {},
  "devDependencies": {
    "electron":         "^29.1.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId":       "com.arman.store",
    "productName": "Smart Store",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }]
    },
    "nsis": {
      "oneClick":          false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}
