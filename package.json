{
  "name": "smart-store",
  "version": "3.1.0",
  "description": "Smart Store — Smart Store Warehouse Management System",
  "main": "src/main.js",
  "author": "Smart Store",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "build:win32": "electron-builder --win --ia32"
  },
  "dependencies": {
    "electron-store": "^8.1.0"
  },
  "devDependencies": {
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.smartstore.wms",
    "productName": "Smart Store",
    "copyright": "© 2026 Smart Store",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64", "ia32"] }
      ],
      "icon": "assets/icon.ico",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Smart Store"
    },
    "publish": [
      {
        "provider": "generic",
        "url": "https://www.ahrtechdiv.com/downloads/"
      }
    ],
    "extraMetadata": {
      "electron": {
        "nodeIntegration": false,
        "contextIsolation": true,
        "sandbox": true
      }
    }
  }
}
